# Copy this file to .env for local development (never commit the real .env).
# On Streamlit Community Cloud, set these in Advanced settings -> Secrets instead.

OPENAI_API_KEY=sk-your-openai-key-here

# Used for automated Intron login on headless/cloud deployments, where
# nobody can see the browser window to log in manually. Only works if
# Intron's login is a plain email+password form -- it can't get past a
# CAPTCHA or an emailed verification code.
INTRON_EMAIL=your-intron-login-email@example.com
INTRON_PASSWORD=your-intron-password
